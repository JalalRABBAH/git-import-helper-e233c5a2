{
  "dashboard": {
    "id": null,
    "uid": "ireg-api-perf",
    "title": "iReg Moto BF — API Performance",
    "tags": ["ireg", "api", "performance"],
    "timezone": "Africa/Ouagadougou",
    "schemaVersion": 36,
    "refresh": "15s",
    "panels": [
      {
        "id": 1,
        "title": "Requêtes par seconde",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(ireg_http_requests_total[5m]))",
            "legendFormat": "RPS"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 500},
                {"color": "red", "value": 1000}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Latence P50 / P95 / P99",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(ireg_http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(ireg_http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(ireg_http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 3}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Taux d'erreur HTTP",
        "type": "stat",
        "targets": [
          {
            "expr": "(sum(rate(ireg_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(ireg_http_requests_total[5m]))) * 100",
            "legendFormat": "Erreurs 5xx %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 4,
        "title": "Distribution des codes HTTP",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum(rate(ireg_http_requests_total[5m])) by (status)",
            "legendFormat": "{{status}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8}
      },
      {
        "id": 5,
        "title": "Latence par endpoint (P95)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(ireg_http_request_duration_seconds_bucket[5m])) by (handler, le))",
            "legendFormat": "{{handler}}"
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "s"}
        },
        "gridPos": {"h": 8, "w": 16, "x": 8, "y": 8}
      },
      {
        "id": 6,
        "title": "Pods backend (actifs / désirés)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "kube_deployment_status_replicas_available{deployment=\"backend\"}",
            "legendFormat": "Disponibles"
          },
          {
            "expr": "kube_deployment_spec_replicas{deployment=\"backend\"}",
            "legendFormat": "Désirés"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 7,
        "title": "CPU / Mémoire Backend",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{pod=~\"backend-.*\"}[5m])",
            "legendFormat": "CPU {{pod}}"
          },
          {
            "expr": "container_memory_usage_bytes{pod=~\"backend-.*\"} / 1024 / 1024",
            "legendFormat": "Mem MB {{pod}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      }
    ]
  }
}